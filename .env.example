# Cap Environment Variables Template
# Copy this to .env and fill in the values

# Public URLs
CAP_URL=https://rec.syscomatic.cloud
S3_PUBLIC_URL=https://s3.rec.syscomatic.cloud

# Database Configuration (Docker)
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# MinIO Storage Credentials
MINIO_ROOT_USER=cap-admin
MINIO_ROOT_PASSWORD=

# Security Secrets (Generate using 'openssl rand -hex 32')
DATABASE_ENCRYPTION_KEY=
NEXTAUTH_SECRET=
MEDIA_SERVER_WEBHOOK_SECRET=

# Optional: Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_DOMAIN=syscomatic.cloud
